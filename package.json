{
  "name": "lynx-agent-spinners",
  "version": "1.0.0",
  "description": "55 terminal-style text spinners — React Native + LynxJS port, 87% shared code",
  "repository": {
    "type": "git",
    "url": "https://github.com/Huxpro/lynx-agent-spinners.git"
  },
  "author": "Huxpro (Lynx port) · eronred (original RN library)",
  "license": "MIT",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "expo:ios": "expo start --ios",
    "expo:android": "expo start --android",
    "expo:web": "expo start --web",
    "lynx:dev": "pnpm --filter ./apps/lynx dev",
    "lynx:build": "pnpm --filter ./apps/lynx build",
    "lynx:preview": "pnpm --filter ./apps/lynx preview",
    "screens:build": "pnpm --filter ./apps/screens build",
    "preso:build": "pnpm lynx:build && pnpm screens:build && node presentation/extract-spinners.mjs && bash presentation/sync-lynx-app.sh",
    "preso": "pnpm preso:build && bash presentation/serve.sh"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
